{
  "name": "biobase_desktop_client",
  "version": "0.1.0",
  "private": true,
  "description": "Biobase Windows desktop client for CS2 demo parsing, overlay HUD, stats dashboard, and central sync.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "npm run build && electron .",
    "dist:win": "npm run dist:win:installer",
    "lint:config": "node scripts/validate-config.mjs",
    "test": "npm run build:main && node --test tests/*.test.mjs",
    "typecheck": "npm run build:main && tsc -p tsconfig.json --noEmit",
    "dist:win:unsigned": "npm run dist:win:installer:unsigned",
    "dist:win:dir": "npm run build && electron-builder --win dir --config.win.signAndEditExecutable=false",
    "dist:win:installer": "npm run build && electron-builder --win nsis",
    "dist:win:installer:unsigned": "npm run build && electron-builder --win nsis --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "@laihoe/demoparser2": "^0.41.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "typescript": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.biobase.client",
    "productName": "Biobase Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Biobase-Client-${version}-${arch}.${ext}",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterSign": "scripts/after-sign.cjs",
    "artifactName": "Biobase-Client-Setup-${version}-${arch}.${ext}"
  },
  "author": "BioBase Live"
}
