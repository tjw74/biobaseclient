  "panels": [
    {
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "### Start bot game + collect into Postgres\nFrom the **biobase repo root** on the Docker host:\n```bash\nDURATION_SEC=120 ./tools/run_ingest_session.sh\n# or:  DURATION_SEC=120 ./tools/run_kz_session.sh\n```\nEnv: `DATA_URL=http://127.0.0.1:28080` (default), `CS2_URL=http://127.0.0.1:8765`. **Monitor** below: **Live** = `bb_monitor_rcon` → Prometheus (every ~10s). **Postgres** = rows from `POST /v1/sessions` runs. API summary: `GET /v1/sessions/{id}/summary`.",
        "mode": "markdown"
      },
      "title": "How to run & where data goes",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 100,
      "title": "Live — game / RCON (Prometheus)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "description": "1 = last mcrcon `status` succeeded (server up, password OK).",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "Down / fail" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "RCON OK" } }, "type": "value" }
          ],
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 6 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "bb-prometheus" }, "editorMode": "code", "expr": "max(rcon_up)", "instant": true, "refId": "A" }],
      "title": "Server reachable (RCON)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "description": "Bot count from parsed `status` (CS2: N humans, M bots). -1 = unknown.",
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "-1": { "index": 0, "text": "?" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 6 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "bb-prometheus" }, "editorMode": "code", "expr": "max(rcon_status_bots)", "instant": true, "refId": "A" }],
      "title": "Bots (live)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "description": "Humans on server (from CS2 status line when parsed).",
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "-1": { "index": 0, "text": "?" } }, "type": "value" }], "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 6 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "bb-prometheus" }, "editorMode": "code", "expr": "max(rcon_status_players)", "instant": true, "refId": "A" }],
      "title": "Humans (live)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "options": { "-1": { "index": 0, "text": "?" } }, "type": "value" }], "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 6 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "bb-prometheus" }, "editorMode": "code", "expr": "max(rcon_status_max_players)", "instant": true, "refId": "A" }],
      "title": "Max slots",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "description": "Derived: bots \u003e 0 and RCON up — quick “bot game active” signal.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "orange", "index": 0, "text": "No / unknown" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "Likely running" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 6 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
          "editorMode": "code",
          "expr": "max( (rcon_up > 0) * (rcon_status_bots > 0) )",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Bot game running? (heuristic)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "description": "Labels from last status parse (map + hostname).",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 5, "w": 10, "x": 0, "y": 10 },
      "id": 7,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "reducers": [] }, "showHeader": true },
      "pluginVersion": "11.0.0",
      "targets": [
