        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true }, "indexByName": {}, "renameByName": {} } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 10 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "bb-prometheus" },
