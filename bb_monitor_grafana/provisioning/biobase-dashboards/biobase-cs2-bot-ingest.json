    {
      "datasource": { "type": "postgres", "uid": "bb-postgres" },
      "description": "Public CS2 ingest tables — use for spot-checking schema in Grafana.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 20,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "reducers": [] }, "showHeader": true },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "bb-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT table_name, column_name, data_type, is_nullable\nFROM information_schema.columns\nWHERE table_schema = 'public'\n  AND table_name IN ('biobase_cs2_match_session', 'biobase_cs2_rcon_sample', 'biobase_cs2_log_line', 'biobase_ingest_sample')\nORDER BY table_name, ordinal_position",
          "refId": "A"
        }
      ],
      "title": "Table schema (CS2 ingest)",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "bb-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 29 },
      "id": 21,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "reducers": [] }, "showHeader": true },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "bb-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (SELECT count(*)::bigint FROM public.biobase_cs2_match_session) AS match_sessions,\n       (SELECT count(*)::bigint FROM public.biobase_cs2_rcon_sample) AS rcon_samples,\n       (SELECT count(*)::bigint FROM public.biobase_cs2_log_line) AS log_lines,\n       (SELECT count(*)::bigint FROM public.biobase_ingest_sample) AS ingest_stub_rows",
          "refId": "A"
        }
      ],
      "title": "Row counts (ingest)",
      "type": "table"
    },
