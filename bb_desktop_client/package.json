{
  "name": "biobase_desktop_client",
  "version": "0.1.0",
  "private": true,
  "description": "Biobase Windows desktop client for CS2 demo parsing, overlay HUD, stats dashboard, and central sync.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "start": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "lint:config": "node scripts/validate-config.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "typescript": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.1",
    "@laihoe/demoparser2": "^0.41.3"
  },
  "devDependencies": {},
  "build": {
    "appId": "com.biobase.client",
    "productName": "Biobase Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Biobase-Client-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
