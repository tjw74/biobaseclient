# Client-shipped stack (bb_postgres + bb_data_collection). Copy to .env and set secrets.
POSTGRES_USER=biobase
POSTGRES_PASSWORD=change-me
POSTGRES_DB=biobase

# bb_data_collection API (orchestration script uses this; containers use service DNS by default)
BB_DATA_COLLECTION_PORT=28080
LOKI_URL=http://bb_monitor_loki:3100
CS2_CONTROL_URL=http://bb_cs2_control:8765
# Optional; must match CS2 RCON if bb_cs2_control is token-protected
# CS2_CONTROL_TOKEN=
