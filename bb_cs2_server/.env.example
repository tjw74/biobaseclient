# Copy to .env and adjust. See scripts/apply-clips-bind.sh (run from
# /home/clearmined/code/prod/biobase/bb_cs2_server on ClarionCore).
#
# Production: exact path on ClarionCore (writable via bind — see README / fstab).
BB_CLIPS_HOST_DIR=/mnt/backups/biobase/clips

# CS2 server profile: play (default) = combat/no KZ; practice|kz = CS2KZ + biobase_dev.cfg (see README.md).
# BB_CS2_SERVER_PROFILE=play
# MatchZy (CounterStrikeSharp) plugin unpacked by pre.sh — default ON; use 0 to skip:
# BB_CS2_ENABLE_MATCHZY=1
# CS2_CHEATS=0

# Dashboard login shared secret (Bearer / login password):
# BB_CS2_DASHBOARD_TOKEN=change-me

# Optional: if Docker cannot bind /mnt/... on your host, set a path the daemon may use:
# BB_CLIPS_HOST_DIR=/var/lib/biobase/clips

# Optional: CS2_KZ/developer stack (default play = normal CS2).
# BB_CS2_SERVER_PROFILE=practice
