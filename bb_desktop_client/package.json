{
  "name": "biobase_desktop_client",
  "version": "0.5.2",
  "private": true,
  "description": "Biobase desktop client for CS2 demo parsing, overlay HUD, stats dashboard, live player observation, and central sync.",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:main && npm run build:preload && npm run build:watchdog && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json && node scripts/rename-preload.cjs.mjs",
    "build:watchdog": "node scripts/copy-watchdog.cjs.mjs",
    "start": "npm run build && electron .",
    "dist:win": "npm run dist:win:installer",
    "lint:config": "node scripts/validate-config.mjs",
    "test": "npm run build:main && node --test tests/*.test.mjs",
    "typecheck": "npm run build:main && npm run build:preload && tsc -p tsconfig.json --noEmit",
    "dist:win:unsigned": "npm run dist:win:installer:unsigned",
    "dist:win:dir": "npm run build && electron-builder --win dir --config.win.signAndEditExecutable=false",
    "dist:win:installer": "npm run build && electron-builder --win nsis",
    "dist:win:installer:unsigned": "npm run build && WINEDEBUG=-all electron-builder --win nsis --config.win.signAndEditExecutable=false --config.nsis.differentialPackage=false --config.nsis.oneClick=true --config.nsis.runAfterFinish=true --config.nsis.createDesktopShortcut=true --config.nsis.createStartMenuShortcut=true --config.nsis.allowToChangeInstallationDirectory=false --config.artifactName='biobase-client-setup.${ext}'",
    "dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --config.mac.identity=null",
    "dist:mac:dmg": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --config.mac.identity=null"
  },
  "dependencies": {
    "@laihoe/demoparser2": "^0.41.3",
    "electron-updater": "^6.8.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.biobase.client",
    "productName": "Biobase Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "scripts/windows/virtual-desktop-isolation.ps1"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.games",
      "artifactName": "biobase-client-${version}-${arch}.${ext}",
      "identity": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "differentialPackage": false
    },
    "afterSign": "scripts/after-sign.cjs",
    "artifactName": "biobase-client-setup.${ext}",
    "publish": {
      "provider": "generic",
      "url": "https://cs2.clarionlab.dev/client/"
    }
  },
  "author": "BioBase Live"
}
