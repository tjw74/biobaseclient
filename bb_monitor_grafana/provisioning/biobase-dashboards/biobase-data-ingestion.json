    {
      "datasource": { "type": "postgres", "uid": "bb-postgres" },
      "description": "Row counts per `game` table plus raw `ops` log lines.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 5 },
      "id": 8,
      "options": { "cellHeight": "sm", "footer": { "countRows": false, "reducers": [] }, "showHeader": true },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "bb-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (SELECT count(*)::bigint FROM game.biobase_cs2_game_event)           AS game_event,\n       (SELECT count(*)::bigint FROM game.biobase_cs2_movement_sample)        AS movement_sample,\n       (SELECT count(*)::bigint FROM game.biobase_cs2_round_stats)            AS round_stats,\n       (SELECT count(*)::bigint FROM game.biobase_cs2kz_sqlite_cursor)       AS cs2kz_sqlite_cursor,\n       (SELECT count(*)::bigint FROM game.biobase_cs2kz_player)              AS cs2kz_player,\n       (SELECT count(*)::bigint FROM game.biobase_cs2kz_run)                 AS cs2kz_run,\n       (SELECT count(*)::bigint FROM game.biobase_cs2kz_jumpstat)           AS cs2kz_jumpstat,\n       (SELECT count(*)::bigint FROM ops.biobase_cs2_log_line)               AS ops_log_lines",
          "refId": "A"
        }
      ],
      "title": "Quick counts",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "bb-postgres" },
